<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="500.0" prefWidth="600.0" stylesheets="@register.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.RegisterController">
    <children>

        <VBox alignment="CENTER" maxHeight="450.0" maxWidth="400.0" spacing="15.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>

                <Label text="Create Account">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Label text="Start managing your time with FocusFlow" textFill="#6b6b6b">
                    <VBox.margin>
                        <Insets bottom="10.0" top="-10.0" />
                    </VBox.margin>
                </Label>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Username" textFill="#333333">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="usernameField" prefHeight="40.0" promptText="Choose a username" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Email" textFill="#333333">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="emailField" prefHeight="40.0" promptText="Enter your email" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Password" textFill="#333333">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Create a strong password" />
                    </children>
                </VBox>

                <Button mnemonicParsing="false" onAction="#registerUser" prefHeight="45.0" prefWidth="320.0" text="SIGN UP">
                    <font>
                        <Font size="14.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>

                <Hyperlink onAction="#switchToLogin" text="Already have an account? Log in here" textFill="#3498db">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Hyperlink>

            </children>
        </VBox>
    </children>
</StackPane>
