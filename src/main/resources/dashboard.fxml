<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="dashboardScreen" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" styleClass="root" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.DashboardController">
   <right>
      <VBox alignment="CENTER" prefHeight="544.0" prefWidth="183.0" spacing="52.0" styleClass="side-menu" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="makeSchedule" mnemonicParsing="false" onAction="#createSchedule" prefHeight="43.0" prefWidth="181.0" styleClass="nav-button" text="Create Schedule" wrapText="true" />
            <Button fx:id="showSchedule" mnemonicParsing="false" onAction="#seeSchedule" prefHeight="42.0" prefWidth="168.0" styleClass="nav-button" text="Show Schedule" wrapText="true" />
            <Button fx:id="makeSummary" mnemonicParsing="false" onAction="#generateSummary" prefHeight="42.0" prefWidth="212.0" styleClass="nav-button" text="Get Summary" wrapText="true" />
            <Button mnemonicParsing="false" onAction="#takeQuiz" prefHeight="42.0" prefWidth="169.0" styleClass="nav-button" text="Quiz" />
            <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#checkLogout" prefHeight="42.0" prefWidth="173.0" styleClass="logout-button" text="Log Out" />
         </children>
      </VBox>
   </right>
   <center>
      <AnchorPane prefHeight="482.0" prefWidth="645.0" styleClass="center-pane" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="showText" layoutX="302.0" layoutY="229.0" prefHeight="38.0" prefWidth="73.0" textAlignment="CENTER" textFill="#3cc5c9">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
   </center>
   <top>
      <AnchorPane prefHeight="92.0" prefWidth="800.0" BorderPane.alignment="CENTER">
         <children>
            <ProgressBar fx:id="progressBar" layoutX="287.0" layoutY="5.0" prefWidth="200.0" progress="0.0" styleClass="top-bar" />
            <HBox alignment="TOP_RIGHT" layoutX="-7.0" layoutY="25.0" prefHeight="48.0" prefWidth="800.0">
               <children>
                  <Circle fx:id="picCircle" centerX="25.0" centerY="25.0" fill="DODGERBLUE" radius="25.0" stroke="BLACK" strokeType="INSIDE" />
               </children>
            </HBox>
            <Label layoutX="305.0" layoutY="78.0" styleClass="dashboard-title" text="Dashboard" textAlignment="CENTER" textFill="#3f8ba4">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Button layoutX="6.0" layoutY="75.0" mnemonicParsing="false" onAction="#openSideTaskBar" style="-fx-background-color: black;" styleClass="add-button" text="+" textFill="#fffefe" />
         </children>
      </AnchorPane>
   </top>
   <left>
      <VBox fx:id="sideTaskBar" alignment="TOP_CENTER" managed="false" opacity="0.83" prefHeight="487.0" prefWidth="109.0" spacing="8.0" visible="false" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" text="Add Task">
               <font>
                  <Font name="Century Gothic Bold" size="15.0" />
               </font>
               <padding>
                  <Insets top="15.0" />
               </padding>
            </Label>
            <Label text="Task Name">
               <font>
                  <Font name="Century Gothic" size="12.0" />
               </font>
               <padding>
                  <Insets top="12.0" />
               </padding>
               <VBox.margin>
                  <Insets top="8.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="taskField" prefHeight="21.0" prefWidth="107.0" promptText="e.g Physics/Reading">
               <padding>
                  <Insets top="3.0" />
               </padding>
               <VBox.margin>
                  <Insets top="8.0" />
               </VBox.margin>
            </TextField>
            <Label prefHeight="25.0" prefWidth="56.0" text="Duration">
               <VBox.margin>
                  <Insets top="7.0" />
               </VBox.margin>
               <font>
                  <Font name="Century Gothic" size="13.0" />
               </font>
            </Label>
            <TextField fx:id="durationField" promptText="e.g 30/60/120" />
            <Button mnemonicParsing="false" onAction="#createTask" text="Add Task">
               <VBox.margin>
                  <Insets top="80.0" />
               </VBox.margin>
               <font>
                  <Font name="Century Gothic Bold" size="13.0" />
               </font>
            </Button>
         </children>
         <padding>
            <Insets top="5.0" />
         </padding></VBox>
   </left>
</BorderPane>
